datasource db {
  provider = "mysql"
}

generator client {
  provider = "prisma-client-js"
}

model Admin {
  id           String   @id @default(uuid())
  username     String   @unique @map("username")
  passwordHash String   @map("password_hash")
  name         String   @default("Administrator") @map("name")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("admins")
}

model Destination {
  id          String    @id @default(uuid())
  destination String    @map("destination")
  countries   Country[]

  @@map("destinations")
}

model Country {
  id               String            @id @default(uuid())
  name             String            @map("name")
  destinationId    String            @map("destination_id")
  destination      Destination       @relation(fields: [destinationId], references: [id])
  cities           City[]
  flights          Flight[]
  returningFlights ReturningFlight[]

  @@map("countries")
}

model City {
  id                  String               @id @default(uuid())
  name                String               @map("name")
  countryId           String               @map("country_id")
  country             Country              @relation(fields: [countryId], references: [id])
  saudiAirports       SaudiAirport[]
  destinationAirports DestinationAirport[]
  departureTransports InternalTransport[]  @relation("DepartureCity")
  arrivalTransports   InternalTransport[]  @relation("ArrivalCity")

  @@map("cities")
}

model SaudiAirport {
  id               String            @id @default(uuid())
  airportName      String            @map("airport_name")
  cityId           String            @map("city_id")
  city             City              @relation(fields: [cityId], references: [id])
  flights          Flight[]          @relation("SaudiDepartedFlights")
  returningFlights ReturningFlight[] @relation("SaudiArrivalFlights")

  @@map("saudi_airports")
}

model DestinationAirport {
  id               String            @id @default(uuid())
  airportName      String            @map("airport_name")
  cityId           String            @map("city_id")
  city             City              @relation(fields: [cityId], references: [id])
  flights          Flight[]          @relation("DestinationArrivalFlights")
  returningFlights ReturningFlight[] @relation("DestinationDepartedFlights")

  @@map("destination_airports")
}

model Flight {
  id                 String              @id @default(uuid())
  countryId          String              @map("country_id")
  country            Country             @relation(fields: [countryId], references: [id])
  approximatePrice   Int                 @map("approximate_price")
  airWayName         String              @map("air_way_name")
  arrivalAirportId   String              @map("arrival_airport_id")
  arrivalAirport     DestinationAirport  @relation("DestinationArrivalFlights", fields: [arrivalAirportId], references: [id])
  departedAirportId  String              @map("departed_airport_id")
  departedAirport    SaudiAirport        @relation("SaudiDepartedFlights", fields: [departedAirportId], references: [id])
  customizedPackages CustomizedPackage[]
  companyPackages    CompanyPackage[]    @relation("CompanyDepartingFlights")

  @@map("flights")
}

model InternalTransport {
  id                 String @id @default(uuid())
  transportationName String @map("transportation_name")
  approximatePrice   Int    @map("approximate_price")
  cityId             String @map("city_id")
  departureCity      City   @relation("DepartureCity", fields: [cityId], references: [id])
  arrivalCityId      String @map("arrival_city_id")
  arrivalCity        City   @relation("ArrivalCity", fields: [arrivalCityId], references: [id])

  @@map("internal_transports")
}

model ReturningFlight {
  id                 String              @id @default(uuid())
  countryId          String              @map("country_id")
  country            Country             @relation(fields: [countryId], references: [id])
  approximatePrice   Int                 @map("approximate_price")
  airWayName         String              @map("air_way_name")
  arrivalAirportId   String              @map("arrival_airport_id")
  arrivalAirport     SaudiAirport        @relation("SaudiArrivalFlights", fields: [arrivalAirportId], references: [id])
  departedAirportId  String              @map("departed_airport_id")
  departedAirport    DestinationAirport  @relation("DestinationDepartedFlights", fields: [departedAirportId], references: [id])
  customizedPackages CustomizedPackage[]
  companyPackages    CompanyPackage[]    @relation("CompanyReturningFlights")

  @@map("returning_flights")
}

model CustomizedPackage {
  id                String           @id @default(uuid())
  clientName        String           @map("client_name")
  clientPhone       String           @map("client_phone")
  startDate         String           @map("start_date")
  endDate           String           @map("end_date")
  departingFlightId String?          @map("departing_flight_id")
  departingFlight   Flight?          @relation(fields: [departingFlightId], references: [id])
  returningFlightId String?          @map("returning_flight_id")
  returningFlight   ReturningFlight? @relation(fields: [returningFlightId], references: [id])
  pricing           Int              @map("pricing")
  cityStays         Json             @map("city_stays")
  createdAt         DateTime         @default(now()) @map("created_at")
  packageItems      PackageItem[]
  companyPackageId  String?          @map("company_package_id")
  companyPackage    CompanyPackage?  @relation("CompanyPackageBookings", fields: [companyPackageId], references: [id])
  invoices          Invoice[]
  receiptVouchers   ReceiptVoucher[]
  paymentVouchers   PaymentVoucher[]
  supplierInvoices  SupplierInvoice[]
  supportTickets    SupportTicket[]

  @@map("customized_packages")
}

model CompanyPackage {
  id              String        @id @default(uuid())
  name            String        @map("name")
  title           String        @map("title")
  description     String        @map("description") @db.Text
  pricing         Int           @map("pricing")
  originalPricing Int?          @map("original_pricing")
  days            String        @map("days")
  image           String        @map("image")
  popular         Boolean       @default(false) @map("popular")
  rating          Int           @default(5) @map("rating")
  reviews         Int           @default(0) @map("reviews")
  features        Json          @map("features")
  includesText    String        @map("includes_text")
  countryCode     String?       @map("country_code")
  destinationCode String?       @map("destination_code")
  packageItems    PackageItem[]

  departingFlightId String?             @map("departing_flight_id")
  departingFlight   Flight?             @relation("CompanyDepartingFlights", fields: [departingFlightId], references: [id])
  returningFlightId String?             @map("returning_flight_id")
  returningFlight   ReturningFlight?    @relation("CompanyReturningFlights", fields: [returningFlightId], references: [id])
  cityStays         Json?               @map("city_stays")
  bookings          CustomizedPackage[] @relation("CompanyPackageBookings")
  createdAt         DateTime            @default(now()) @map("created_at")

  @@map("company_packages")
}

model OtpCode {
  id        String   @id @default(uuid())
  phone     String   @map("phone") @unique
  codeHash  String   @map("code_hash")
  expiresAt DateTime @map("expires_at")
  attempts  Int      @default(0) @map("attempts")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([phone, createdAt])
  @@map("otp_codes")
}

model PackageItem {
  id                  String             @id @default(uuid())
  flightId            String?            @map("flight_id")
  customizedPackageId String?            @map("customized_package_id")
  customizedPackage   CustomizedPackage? @relation(fields: [customizedPackageId], references: [id])
  companyPackageId    String?            @map("company_package_id")
  companyPackage      CompanyPackage?    @relation(fields: [companyPackageId], references: [id])

  @@map("package_items")
}

// ============================================================
// Accounting (double-entry) module
// ============================================================

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalSourceType {
  MANUAL
  INVOICE
  RECEIPT
  PAYMENT
  SUPPLIER_INVOICE
  REVERSAL
}

enum InvoiceStatus {
  ISSUED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  OTHER
}

enum SupplierInvoiceStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  CANCELLED
}

model Account {
  id              String           @id @default(uuid())
  code            String           @unique @map("code")
  name            String           @map("name")
  type            AccountType      @map("type")
  // System accounts are seeded and used by automatic postings — they can't be deleted
  isSystem        Boolean          @default(false) @map("is_system")
  isActive        Boolean          @default(true) @map("is_active")
  journalLines     JournalLine[]
  paymentVouchers  PaymentVoucher[]  @relation("VoucherExpenseAccount")
  supplierInvoices SupplierInvoice[] @relation("SupplierInvoiceExpenseAccount")
  createdAt        DateTime          @default(now()) @map("created_at")

  @@map("accounts")
}

model JournalEntry {
  id              String            @id @default(uuid())
  entryNumber     Int               @unique @default(autoincrement()) @map("entry_number")
  date            DateTime          @map("date")
  description     String            @map("description")
  reference       String?           @map("reference")
  sourceType      JournalSourceType @default(MANUAL) @map("source_type")
  lines           JournalLine[]
  invoice         Invoice?
  receipt         ReceiptVoucher?
  payment         PaymentVoucher?
  supplierInvoice SupplierInvoice?
  createdAt       DateTime          @default(now()) @map("created_at")

  @@index([date])
  @@map("journal_entries")
}

model JournalLine {
  id          String       @id @default(uuid())
  entryId     String       @map("entry_id")
  entry       JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  accountId   String       @map("account_id")
  account     Account      @relation(fields: [accountId], references: [id])
  debit       Decimal      @default(0) @map("debit") @db.Decimal(14, 2)
  credit      Decimal      @default(0) @map("credit") @db.Decimal(14, 2)
  description String?      @map("description")

  @@index([accountId])
  @@map("journal_lines")
}

model Invoice {
  id                  String             @id @default(uuid())
  invoiceNumber       Int                @unique @default(autoincrement()) @map("invoice_number")
  status              InvoiceStatus      @default(ISSUED) @map("status")
  issueDate           DateTime           @default(now()) @map("issue_date")
  dueDate             DateTime?          @map("due_date")
  clientName          String             @map("client_name")
  clientPhone         String?            @map("client_phone")
  clientVatNumber     String?            @map("client_vat_number")
  clientAddress       String?            @map("client_address")
  customizedPackageId String?            @map("customized_package_id")
  customizedPackage   CustomizedPackage? @relation(fields: [customizedPackageId], references: [id])
  items               InvoiceItem[]
  subtotal            Decimal            @map("subtotal") @db.Decimal(14, 2)
  vatRate             Decimal            @default(15) @map("vat_rate") @db.Decimal(5, 2)
  vatAmount           Decimal            @map("vat_amount") @db.Decimal(14, 2)
  total               Decimal            @map("total") @db.Decimal(14, 2)
  paidAmount          Decimal            @default(0) @map("paid_amount") @db.Decimal(14, 2)
  notes               String?            @map("notes") @db.Text
  journalEntryId      String?            @unique @map("journal_entry_id")
  journalEntry        JournalEntry?      @relation(fields: [journalEntryId], references: [id])
  receipts            ReceiptVoucher[]
  createdAt           DateTime           @default(now()) @map("created_at")

  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String  @map("invoice_id")
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String  @map("description")
  quantity    Decimal @default(1) @map("quantity") @db.Decimal(10, 2)
  unitPrice   Decimal @map("unit_price") @db.Decimal(14, 2)
  lineTotal   Decimal @map("line_total") @db.Decimal(14, 2)

  @@map("invoice_items")
}

// سند قبض
model ReceiptVoucher {
  id                  String             @id @default(uuid())
  receiptNumber       Int                @unique @default(autoincrement()) @map("receipt_number")
  date                DateTime           @default(now()) @map("date")
  amount              Decimal            @map("amount") @db.Decimal(14, 2)
  method              PaymentMethod      @default(CASH) @map("method")
  clientName          String             @map("client_name")
  invoiceId           String?            @map("invoice_id")
  invoice             Invoice?           @relation(fields: [invoiceId], references: [id])
  customizedPackageId String?            @map("customized_package_id")
  customizedPackage   CustomizedPackage? @relation(fields: [customizedPackageId], references: [id])
  notes               String?            @map("notes")
  journalEntryId      String?            @unique @map("journal_entry_id")
  journalEntry        JournalEntry?      @relation(fields: [journalEntryId], references: [id])
  cancelledAt         DateTime?          @map("cancelled_at")
  createdAt           DateTime           @default(now()) @map("created_at")

  @@map("receipt_vouchers")
}

// سند صرف (مصروفات عامة أو تكاليف رحلة)
model PaymentVoucher {
  id                  String             @id @default(uuid())
  voucherNumber       Int                @unique @default(autoincrement()) @map("voucher_number")
  date                DateTime           @default(now()) @map("date")
  amount              Decimal            @map("amount") @db.Decimal(14, 2)
  vatAmount           Decimal            @default(0) @map("vat_amount") @db.Decimal(14, 2)
  method              PaymentMethod      @default(CASH) @map("method")
  payee               String             @map("payee")
  description         String             @map("description")
  expenseAccountId    String?            @map("expense_account_id")
  expenseAccount      Account?           @relation("VoucherExpenseAccount", fields: [expenseAccountId], references: [id])
  customizedPackageId String?            @map("customized_package_id")
  customizedPackage   CustomizedPackage? @relation(fields: [customizedPackageId], references: [id])
  supplierInvoiceId   String?            @map("supplier_invoice_id")
  supplierInvoice     SupplierInvoice?   @relation(fields: [supplierInvoiceId], references: [id])
  journalEntryId      String?            @unique @map("journal_entry_id")
  journalEntry        JournalEntry?      @relation(fields: [journalEntryId], references: [id])
  cancelledAt         DateTime?          @map("cancelled_at")
  createdAt           DateTime           @default(now()) @map("created_at")

  @@map("payment_vouchers")
}

// فاتورة مورد (مشتريات آجلة) — المصروف يُعترف به عند الاستلام والسداد لاحقاً
model SupplierInvoice {
  id                  String                @id @default(uuid())
  invoiceNumber       Int                   @unique @default(autoincrement()) @map("invoice_number")
  supplierName        String                @map("supplier_name")
  description         String                @map("description")
  date                DateTime              @default(now()) @map("date")
  dueDate             DateTime?             @map("due_date")
  amount              Decimal               @map("amount") @db.Decimal(14, 2)
  vatAmount           Decimal               @default(0) @map("vat_amount") @db.Decimal(14, 2)
  total               Decimal               @map("total") @db.Decimal(14, 2)
  paidAmount          Decimal               @default(0) @map("paid_amount") @db.Decimal(14, 2)
  status              SupplierInvoiceStatus @default(UNPAID) @map("status")
  expenseAccountId    String                @map("expense_account_id")
  expenseAccount      Account               @relation("SupplierInvoiceExpenseAccount", fields: [expenseAccountId], references: [id])
  customizedPackageId String?               @map("customized_package_id")
  customizedPackage   CustomizedPackage?    @relation(fields: [customizedPackageId], references: [id])
  journalEntryId      String?               @unique @map("journal_entry_id")
  journalEntry        JournalEntry?         @relation(fields: [journalEntryId], references: [id])
  payments            PaymentVoucher[]
  cancelledAt         DateTime?             @map("cancelled_at")
  createdAt           DateTime              @default(now()) @map("created_at")

  @@map("supplier_invoices")
}

// سجل تدقيق للعمليات المحاسبية
model AuditLog {
  id        String   @id @default(uuid())
  action    String   @map("action")
  entity    String   @map("entity")
  entityId  String?  @map("entity_id")
  summary   String   @map("summary")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("audit_logs")
}

// Singleton row (id = "main") holding company/tax info printed on invoices
model AccountingSettings {
  id          String  @id @default("main")
  companyName String  @default("معاون للسياحة") @map("company_name")
  vatNumber   String  @default("") @map("vat_number")
  crNumber    String  @default("") @map("cr_number")
  address     String  @default("") @map("address")
  phone       String  @default("") @map("phone")
  vatRate     Decimal @default(15) @map("vat_rate") @db.Decimal(5, 2)
  // No journal entry may be created or reversed with a date on/before this
  lockDate    DateTime? @map("lock_date")

  @@map("accounting_settings")
}

// ============================================================
// CRM / customer support module
// ============================================================

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketChannel {
  PHONE
  WHATSAPP
  EMAIL
  WEBSITE
  IN_PERSON
  OTHER
}

model Customer {
  id        String          @id @default(uuid())
  name      String          @map("name")
  phone     String          @unique @map("phone")
  email     String?         @map("email")
  city      String?         @map("city")
  notes     String?         @map("notes") @db.Text
  tickets   SupportTicket[]
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @default(now()) @updatedAt @map("updated_at")

  @@map("customers")
}

model SupportTicket {
  id                  String             @id @default(uuid())
  ticketNumber        Int                @unique @default(autoincrement()) @map("ticket_number")
  subject             String             @map("subject")
  description         String?            @map("description") @db.Text
  status              TicketStatus       @default(OPEN) @map("status")
  priority            TicketPriority     @default(MEDIUM) @map("priority")
  channel             TicketChannel      @default(PHONE) @map("channel")
  customerId          String             @map("customer_id")
  customer            Customer           @relation(fields: [customerId], references: [id])
  customizedPackageId String?            @map("customized_package_id")
  customizedPackage   CustomizedPackage? @relation(fields: [customizedPackageId], references: [id])
  assignee            String?            @map("assignee")
  messages            TicketMessage[]
  resolvedAt          DateTime?          @map("resolved_at")
  closedAt            DateTime?          @map("closed_at")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @default(now()) @updatedAt @map("updated_at")

  @@index([status])
  @@index([customerId])
  @@map("support_tickets")
}

model TicketMessage {
  id         String        @id @default(uuid())
  ticketId   String        @map("ticket_id")
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  body       String        @map("body") @db.Text
  authorName String        @default("المسؤول") @map("author_name")
  // Internal notes are visible to staff only (not part of customer-facing history)
  isInternal Boolean       @default(false) @map("is_internal")
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([ticketId])
  @@map("ticket_messages")
}

// بلاغات الأعطال — يرسلها موظفو لوحة التحكم مع لقطة شاشة ليعالجها مختص الـ IT
model BugReport {
  id           String    @id @default(uuid())
  reportNumber Int       @unique @default(autoincrement()) @map("report_number")
  description  String    @map("description") @db.Text
  // Admin route the reporter was on when the bug happened
  page         String    @map("page")
  // JPEG data URL captured client-side at submit time
  screenshot   String?   @map("screenshot") @db.LongText
  reporterName String    @map("reporter_name")
  resolvedAt   DateTime? @map("resolved_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("bug_reports")
}
